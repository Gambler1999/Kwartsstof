function checkQuiz() {
  const name = document.getElementById("emp_name").value.trim();
  const dept = document.getElementById("emp_dept").value;
  const func = document.getElementById("emp_func").value;
  const qs = ["q1","q2","qfoto","q3","q4","q5","q6"];
  const d = docData[currentLang];
  let allOk = true;
  qs.forEach(q => {
    let val = "";
    for (const o of document.getElementsByName(q)) { if (o.checked) val = o.value; }
    const f = document.getElementById("feedback-"+q);
    if (val) {
      if (val==="correct"){f.innerText=d.correct;f.className="feedback correct";}
      else{f.innerText=d.wrong;f.className="feedback wrong";allOk=false;}
    } else { allOk=false; }
  });
  const btn=document.getElementById("submitBtn");
  if(name.length>=2&&dept&&func&&allOk&&!alreadySubmitted){btn.className="btn active";btn.disabled=false;}
  else{btn.className="btn";btn.disabled=true;}
}

function submitToolbox() {
  if(alreadySubmitted)return;
  alreadySubmitted=true;
  document.getElementById("submitBtn").className="btn";
  document.getElementById("submitBtn").disabled=true;
  const name=document.getElementById("emp_name").value.trim();
  const dept=document.getElementById("emp_dept").value;
  const func=document.getElementById("emp_func").value;
  const comments=document.getElementById("emp_comments").value.trim();
  const timestamp=new Date().toLocaleString("nl-NL");
  const logData={time:timestamp,location:dept,worker:name,function:func,language:currentLang.toUpperCase(),toolbox_subject:"Heftruck",comments:comments};
  const webAppUrl="https://script.google.com/macros/s/AKfycbypjgO9Y8AG4O6lPJ_tm2pMPK1R1L5B_6LoNQrfW04AJqyJBZqh65-oT4b1T1zHqmL8/exec";
  fetch(webAppUrl,{method:"POST",mode:"no-cors",headers:{"Content-Type":"application/json"},body:JSON.stringify(logData)})
  .then(()=>showConfirmation(name,func,dept,timestamp))
  .catch(()=>showConfirmation(name,func,dept,timestamp));
}

function showConfirmation(name,func,dept,timestamp){
  const d=docData[currentLang];
  document.getElementById("main-form").style.display="none";
  const conf=document.getElementById("confirmation-screen");
  conf.style.display="block";
  document.getElementById("conf-title").innerText=d.confTitle;
  document.getElementById("conf-sub").innerText=d.confSub;
  document.getElementById("conf-detail").innerHTML=d.confDetail(name,func,dept,timestamp);
  conf.scrollIntoView({behavior:"smooth"});
}
