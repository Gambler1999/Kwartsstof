<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lammers Beton - Toolbox Heftruck</title>
<style>
:root {
--bg-color: #f0f2f5; --card-bg: #ffffff; --text-color: #1a1a1a;
--safety-blue: #28639F; --hazard-amber: #F8C208; --success-green: #2d8a4e;
--border-color: #d0d8e4; --section-bg: #f7f9fb; --danger-red: #c0392b;
}
* { box-sizing: border-box; }
body { font-family: Arial, sans-serif; background-color: var(--bg-color); color: var(--text-color); margin: 0; padding: 20px; display: flex; flex-direction: column; align-items: center; }
.container { max-width: 640px; width: 100%; background: var(--card-bg); border: 1px solid var(--border-color); border-radius: 8px; box-shadow: 0 2px 12px rgba(40,99,159,0.10); overflow: hidden; }
.header-top { background: var(--safety-blue); padding: 16px 24px 14px 24px; }
.header-logo-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; }
.logo-name { font-size: 22px; font-weight: 700; color: #fff; font-family: Arial, sans-serif; letter-spacing: 0.5px; }
.header-badge { background: rgba(255,255,255,0.15); color: #fff; font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 3px; }
.header-top h1 { font-size: 19px; color: #fff; margin: 0 0 3px 0; font-weight: 700; }
.header-top p { color: var(--hazard-amber); margin: 0; font-weight: 700; font-size: 12px; }
.body-wrap { padding: 22px 24px; }
.lang-selector { display: flex; justify-content: center; flex-wrap: wrap; gap: 6px; margin-bottom: 20px; }
.lang-btn { background: #eef2f7; border: 1px solid var(--border-color); color: var(--safety-blue); padding: 6px 13px; border-radius: 4px; cursor: pointer; font-size: 13px; font-weight: bold; font-family: Arial, sans-serif; }
.lang-btn.active { background: var(--safety-blue); border-color: var(--safety-blue); color: #fff; }
.section-card { background: var(--section-bg); border: 1px solid var(--border-color); border-left: 4px solid var(--safety-blue); padding: 16px; margin-bottom: 16px; border-radius: 4px; }
.section-card h3 { margin: 0 0 10px 0; font-size: 15px; color: var(--safety-blue); font-family: Arial, sans-serif; }
.section-card p, .section-card li { font-size: 14px; line-height: 1.6; color: #222; margin: 0 0 8px 0; }
.section-card ol, .section-card ul { padding-left: 20px; margin: 8px 0 0 0; }
.section-card label { font-size: 14px; color: #333; }
input[type="text"], select, textarea { width: 100%; background: #fff; border: 1px solid var(--border-color); color: #222; padding: 10px; border-radius: 4px; box-sizing: border-box; margin-top: 5px; font-family: Arial, sans-serif; font-size: 14px; }
input[type="text"]:focus, select:focus, textarea:focus { outline: none; border-color: var(--safety-blue); box-shadow: 0 0 0 2px rgba(40,99,159,0.12); }
textarea { resize: vertical; }
.quiz-option { display: block; background: #fff; border: 1px solid var(--border-color); padding: 11px 13px; margin-top: 8px; border-radius: 4px; cursor: pointer; font-size: 14px; color: #222; transition: border-color 0.15s; }
.quiz-option:hover { border-color: var(--safety-blue); }
input[type="radio"] { margin-right: 10px; accent-color: var(--safety-blue); }
.feedback { margin-top: 8px; font-weight: bold; font-size: 14px; display: none; }
.feedback.correct { color: var(--success-green); display: block; }
.feedback.wrong { color: #c0392b; display: block; }
.btn { width: 100%; background: #c8d4e0; color: #7a8fa0; border: none; padding: 15px; font-size: 16px; font-weight: bold; border-radius: 4px; cursor: not-allowed; margin-top: 8px; font-family: Arial, sans-serif; }
.btn.active { background: var(--safety-blue); color: #fff; cursor: pointer; }
.btn.active:hover { background: #1e4e7e; }
#confirmation-screen { display: none; text-align: center; padding: 40px 24px; }
.confirm-icon { font-size: 56px; margin-bottom: 16px; }
.confirm-title { font-size: 22px; font-weight: 700; color: var(--success-green); margin-bottom: 10px; font-family: Arial, sans-serif; }
.confirm-sub { font-size: 15px; color: #444; line-height: 1.6; margin-bottom: 20px; }
.confirm-detail { background: var(--section-bg); border: 1px solid var(--border-color); border-radius: 6px; padding: 14px 18px; text-align: left; font-size: 13px; color: #333; line-height: 1.8; margin-bottom: 20px; }
.confirm-detail strong { color: var(--safety-blue); }
.foto-verbod { width: 100%; border-radius: 6px; margin: 10px 0 6px 0; border: 3px solid #c0392b; }
.verbod-label { background: #c0392b; color: white; font-weight: 700; font-size: 13px; text-align: center; padding: 6px; border-radius: 0 0 4px 4px; margin-bottom: 10px; }
.oorzaak-bar { display: grid; grid-template-columns: 22px 80px 1fr 34px; align-items: center; gap: 8px; margin-bottom: 7px; }
.oorzaak-nr { background: var(--safety-blue); color: white; font-weight: 700; font-size: 11px; border-radius: 50%; width: 22px; height: 22px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.oorzaak-nr.rood { background: #c0392b; }
.oorzaak-nr.amber { background: #e07b30; }
.oorzaak-balk-wrap { background: #e8edf2; border-radius: 3px; height: 16px; overflow: hidden; }
.oorzaak-balk { height: 100%; border-radius: 3px; }
.oorzaak-label { font-size: 12px; font-weight: 600; color: #222; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.oorzaak-pct { font-size: 12px; font-weight: 700; color: #333; text-align: right; }
.warning-video-btn { display: flex; align-items: center; justify-content: center; gap: 10px; background: #fff5f5; border: 2px solid #c0392b; border-radius: 6px; padding: 13px; margin-top: 10px; cursor: pointer; text-decoration: none; color: #8b0000; transition: background 0.2s; font-family: Arial, sans-serif; font-size: 13px; font-weight: 700; }
.warning-video-btn:hover { background: #fee; }
.warning-box { background: #fdecea; border: 1px solid #e74c3c; border-left: 4px solid #e74c3c; border-radius: 4px; padding: 10px 14px; font-size: 12px; color: #8b0000; margin-top: 8px; line-height: 1.5; }
</style>
</head>
<body>
<div class="container">
<div class="header-top">
  <div class="header-logo-row">
    <div class="logo-name">Lammers Beton</div>
    <span class="header-badge">KAM</span>
  </div>
  <h1 id="txt-title">Toolbox: Veilig werken met de heftruck</h1>
  <p id="txt-subtitle">Verplichte veiligheidsinstructie</p>
</div>

<div class="body-wrap">
<div class="lang-selector">
  <button class="lang-btn active" onclick="switchLanguage('nl', event)">NL</button>
  <button class="lang-btn" onclick="switchLanguage('en', event)">EN</button>
  <button class="lang-btn" onclick="switchLanguage('pl', event)">PL</button>
  <button class="lang-btn" onclick="switchLanguage('de', event)">DE</button>
  <button class="lang-btn" onclick="switchLanguage('uk', event)">UK</button>
</div>

<div id="main-form">

  <!-- 1. GEGEVENS -->
  <div class="section-card">
    <h3 id="txt-sec1">1. Uw Gegevens</h3>
    <label id="txt-label-name">Volledige naam:</label>
    <input type="text" id="emp_name" oninput="checkQuiz()" placeholder="Vul uw naam in">
    <label id="txt-label-dept" style="display:block;margin-top:10px;">Locatie:</label>
    <select id="emp_dept" onchange="checkQuiz()">
      <option value="">-- Selecteer --</option>
      <option value="Trancheeweg">Trancheeweg</option>
      <option value="Oude Graaf">Oude Graaf</option>
      <option value="Lozerweg">Lozerweg</option>
    </select>
    <label id="txt-label-func" style="display:block;margin-top:10px;">Functie:</label>
    <select id="emp_func" onchange="checkQuiz()">
      <option value="">-- Selecteer --</option>
      <option value="Storter">Storter</option>
      <option value="Afwerker">Afwerker</option>
      <option value="Ontkister">Ontkister</option>
      <option value="Bovenloopkraanmachinist">Bovenloopkraanmachinist</option>
      <option value="Kraanmachinist">Kraanmachinist</option>
      <option value="Betonreparateur">Betonreparateur</option>
      <option value="Productieleider">Productieleider</option>
      <option value="Voorman">Voorman</option>
      <option value="Timmerman">Timmerman</option>
      <option value="Vlechter">Vlechter</option>
      <option value="Expeditiemedewerker">Expeditiemedewerker</option>
      <option value="Magazijnmedewerker">Magazijnmedewerker</option>
      <option value="Technische dienst">Technische dienst</option>
      <option value="Betontechnoloog">Betontechnoloog</option>
      <option value="Molenbaas">Molenbaas</option>
      <option value="Kwaliteitscontroleur">Kwaliteitscontroleur</option>
      <option value="Overig">Overig</option>
    </select>
  </div>

  <!-- 2. OORZAKEN -->
  <div class="section-card">
    <h3 id="txt-sec-info">2. Waardoor gaan het mis bij heftrucks?</h3>
    <p id="txt-info-intro">In Nederland vinden jaarlijks meer dan 150 ernstige heftruckongevallen plaats. Dit zijn de meest voorkomende oorzaken:</p>
    <div id="oorzaken-lijst">
      <div class="oorzaak-bar"><div class="oorzaak-nr rood">1</div><div class="oorzaak-balk-wrap"><div class="oorzaak-balk" style="width:100%;background:#c0392b;"></div></div><span class="oorzaak-label" id="o1-txt">Aanrijdingen met personen</span><span class="oorzaak-pct">41%</span></div>
      <div class="oorzaak-bar"><div class="oorzaak-nr rood">2</div><div class="oorzaak-balk-wrap"><div class="oorzaak-balk" style="width:42%;background:#e74c3c;"></div></div><span class="oorzaak-label" id="o2-txt">Vallende lading</span><span class="oorzaak-pct">17%</span></div>
      <div class="oorzaak-bar"><div class="oorzaak-nr amber">3</div><div class="oorzaak-balk-wrap"><div class="oorzaak-balk" style="width:29%;background:#e07b30;"></div></div><span class="oorzaak-label" id="o3-txt">Val van hoogte</span><span class="oorzaak-pct">12%</span></div>
      <div class="oorzaak-bar"><div class="oorzaak-nr amber">4</div><div class="oorzaak-balk-wrap"><div class="oorzaak-balk" style="width:17%;background:#e07b30;"></div></div><span class="oorzaak-label" id="o4-txt">Zijwaarts kantelen</span><span class="oorzaak-pct">7%</span></div>
      <div class="oorzaak-bar"><div class="oorzaak-nr amber">5</div><div class="oorzaak-balk-wrap"><div class="oorzaak-balk" style="width:17%;background:#e8a020;"></div></div><span class="oorzaak-label" id="o5-txt">Voorover kantelen</span><span class="oorzaak-pct">7%</span></div>
      <div class="oorzaak-bar"><div class="oorzaak-nr" style="background:#7a8fa0;">6</div><div class="oorzaak-balk-wrap"><div class="oorzaak-balk" style="width:15%;background:#7a8fa0;"></div></div><span class="oorzaak-label" id="o6-txt">Beknelling</span><span class="oorzaak-pct">6%</span></div>
      <div class="oorzaak-bar"><div class="oorzaak-nr" style="background:#7a8fa0;">7</div><div class="oorzaak-balk-wrap"><div class="oorzaak-balk" style="width:10%;background:#9aa5b0;"></div></div><span class="oorzaak-label" id="o7-txt">Letsel op/afstappen</span><span class="oorzaak-pct">4%</span></div>
    </div>
    <p id="txt-info-conclusie" style="margin-top:10px;font-size:13px;background:#eaf3fb;border-left:3px solid #28639F;padding:8px 10px;border-radius:3px;color:#1a4a7a;">41% van alle ongelukken is een aanrijding met een voetganger. Dit geldt voor iedereen op het terrein.</p>
  </div>

  <!-- 3. HEFTRUCK BIJ LAMMERS -->
  <div class="section-card">
    <h3 id="txt-sec-lammers">3. Heftruck bij Lammers Beton</h3>
    <div id="txt-body-lammers">
      <p>Bij Lammers Beton rijden heftrucks op dezelfde terreinen als voetgangers, portaalkranen en vrachtwagens. Alleen bevoegde medewerkers met een geldig Veiligheidspaspoort mogen een heftruck bedienen. Dit paspoort is 10 jaar geldig.</p>
      <p><strong>Regels voor de chauffeur:</strong></p>
      <ul>
        <li>Altijd veiligheidsgordel omdoen voor vertrek. Controleer brandstofmeter.</li>
        <li>Maximumsnelheid op het terrein: 15 km/u.</li>
        <li>Vorken maximaal 20 cm boven de vloer tijdens rijden.</li>
        <li>Stap altijd aan de linkerzijde op en af.</li>
        <li>Meld schade of bijzonderheden direct bij de voorman.</li>
        <li>Parkeer nooit op een helling. Zet altijd de parkeerrem.</li>
        <li>Een heftruck is een eenpersoonsvoertuig. Passagiers meenemen is ten strengste verboden.</li>
      </ul>
      <p><strong>Regels voor iedereen op het terrein:</strong></p>
      <ul>
        <li>Blijf altijd op de aangewezen looproute.</li>
        <li>Maak oogcontact met de chauffeur voor het oversteken.</li>
        <li>Sta nooit onder een geheven last of in de bewegingszone van de vorken.</li>
        <li>Houd rekening met de dode hoek achter en rechts van de heftruck.</li>
      </ul>
    </div>

    <!-- DODE HOEK AFBEELDING -->
    <p id="txt-dodehoek-title" style="font-size:13px;font-weight:700;color:#28639F;margin:14px 0 6px 0;">De dode hoek van de heftruck:</p>
    <img src="data:image/png;base64," alt="Dode hoek heftruck" style="width:100%;border-radius:6px;border:1px solid #d0d8e4;margin-bottom:6px;">
  </div>

  <!-- 4. VRAAG 1: VOOR VERTREK -->
  <div class="section-card">
    <h3 id="txt-q1-title">4. Vraag 1 (Voor vertrek)</h3>
    <p id="txt-q1-p">U gaat wegrijden met de heftruck. Wat doet u als eerste?</p>
    <label class="quiz-option"><input type="radio" name="q1" value="wrong" onchange="checkQuiz()"> <span id="txt-q1-o1">Vorken ophogen en direct wegrijden.</span></label>
    <label class="quiz-option"><input type="radio" name="q1" value="correct" onchange="checkQuiz()"> <span id="txt-q1-o2">Veiligheidsgordel omdoen, brandstofmeter controleren, omgeving scannen, dan vorken op 20 cm heffen.</span></label>
    <label class="quiz-option"><input type="radio" name="q1" value="wrong2" onchange="checkQuiz()"> <span id="txt-q1-o3">Claxonneren en direct wegrijden.</span></label>
    <div id="feedback-q1" class="feedback"></div>
  </div>

  <!-- 5. VRAAG 2: MEESTE ONGELUKKEN -->
  <div class="section-card">
    <h3 id="txt-q2-title">5. Vraag 2 (Oorzaken)</h3>
    <p id="txt-q2-p">Wat veroorzaakt de meeste ongelukken bij heftrucks?</p>
    <label class="quiz-option"><input type="radio" name="q2" value="wrong" onchange="checkQuiz()"> <span id="txt-q2-o1">Technische mankementen aan de heftruck.</span></label>
    <label class="quiz-option"><input type="radio" name="q2" value="wrong2" onchange="checkQuiz()"> <span id="txt-q2-o2">Vallende lading door te hoog stapelen.</span></label>
    <label class="quiz-option"><input type="radio" name="q2" value="correct" onchange="checkQuiz()"> <span id="txt-q2-o3">Aanrijdingen van heftrucks met voetgangers (41% van alle ongelukken).</span></label>
    <div id="feedback-q2" class="feedback"></div>
  </div>

  <!-- 5b. VRAAG: IS DIT TOEGESTAAN? FOTO VRAAG -->
  <div class="section-card" style="border-left-color:#c0392b;">
    <h3 id="txt-qfoto-title" style="color:#c0392b;">5b. Is dit toegestaan?</h3>
    <p id="txt-qfoto-p">Bekijk de onderstaande foto. Is deze situatie toegestaan bij Lammers Beton?</p>
    <img src="data:image/png;base64," alt="Meerdere personen op heftruck" style="width:100%;border-radius:6px;margin:10px 0;border:2px solid #d0d8e4;">
    <label class="quiz-option"><input type="radio" name="qfoto" value="wrong" onchange="checkQuiz()"> <span id="txt-qfoto-o1">Ja, dit is toegestaan als ze zich goed vasthouden.</span></label>
    <label class="quiz-option"><input type="radio" name="qfoto" value="correct" onchange="checkQuiz()"> <span id="txt-qfoto-o2">Nee, dit is verboden. Een heftruck is een eenpersoonsvoertuig. Dit kan leiden tot ernstige ongelukken.</span></label>
    <div id="feedback-qfoto" class="feedback"></div>
  </div>

  <!-- 6. VRAAG 3: PASSAGIER VERBOD -->
  <div class="section-card">
    <h3 id="txt-q3-title">6. Vraag 3 (Mag dit?)</h3>
    <p id="txt-q3-p">Een collega vraagt of hij mee mag rijden op de treeplank van de heftruck. Wat doet u?</p>
    <label class="quiz-option"><input type="radio" name="q3" value="wrong" onchange="checkQuiz()"> <span id="txt-q3-o1">Goed, hij kan op de treeplank staan als hij zich vasthoudt.</span></label>
    <label class="quiz-option"><input type="radio" name="q3" value="correct" onchange="checkQuiz()"> <span id="txt-q3-o2">Dit is verboden. Een heftruck is een eenpersoonsvoertuig. Ik weiger dit en wijs de collega op de gevaren.</span></label>
    <label class="quiz-option"><input type="radio" name="q3" value="wrong2" onchange="checkQuiz()"> <span id="txt-q3-o3">Alleen als het een korte afstand is en ik langzaam rij.</span></label>
    <div id="feedback-q3" class="feedback"></div>
  </div>

  <!-- 7. VRAAG 4: VOETGANGER DODE HOEK -->
  <div class="section-card">
    <h3 id="txt-q4-title">7. Vraag 4 (Voetganger)</h3>
    <p id="txt-q4-p">U wilt een rijroute oversteken waar ook heftrucks rijden. Wat is de juiste handelwijze?</p>
    <label class="quiz-option"><input type="radio" name="q4" value="wrong" onchange="checkQuiz()"> <span id="txt-q4-o1">Snel oversteken als er geen heftruck te zien is.</span></label>
    <label class="quiz-option"><input type="radio" name="q4" value="wrong2" onchange="checkQuiz()"> <span id="txt-q4-o2">Wachten tot de rijroute helemaal vrij is, dan snel oversteken.</span></label>
    <label class="quiz-option"><input type="radio" name="q4" value="correct" onchange="checkQuiz()"> <span id="txt-q4-o3">Aangewezen oversteekplaats gebruiken, beide kanten kijken, oogcontact maken met de chauffeur, dan pas oversteken.</span></label>
    <div id="feedback-q4" class="feedback"></div>
  </div>

  <!-- 8. VRAAG 5: SCHADE MELDEN -->
  <div class="section-card">
    <h3 id="txt-q5-title">8. Vraag 5 (Schade melden)</h3>
    <p id="txt-q5-p">Bij aankomst ziet u een olievlek en een deuk in de beschermkooi van de heftruck. Wat doet u?</p>
    <label class="quiz-option"><input type="radio" name="q5" value="wrong" onchange="checkQuiz()"> <span id="txt-q5-o1">Instappen en wegrijden, kleine schade hoeft niet gemeld te worden.</span></label>
    <label class="quiz-option"><input type="radio" name="q5" value="correct" onchange="checkQuiz()"> <span id="txt-q5-o2">Direct melden bij de voorman en de heftruck niet gebruiken totdat de schade beoordeeld is.</span></label>
    <label class="quiz-option"><input type="radio" name="q5" value="wrong2" onchange="checkQuiz()"> <span id="txt-q5-o3">Een foto nemen en aan het einde van de dag melden.</span></label>
    <div id="feedback-q5" class="feedback"></div>
  </div>

  <!-- 9. VRAAG 6: HEFVERMOGEN + VIDEO -->
  <div class="section-card">
    <h3 id="txt-q6-title">9. Vraag 6 (Maximaal hefvermogen)</h3>
    <p id="txt-q6-p">Het element dat u moet tillen is zwaarder dan het maximale hefvermogen op de capaciteitsplaat. Wat doet u?</p>
    <label class="quiz-option"><input type="radio" name="q6" value="wrong" onchange="checkQuiz()"> <span id="txt-q6-o1">Voorzichtig proberen, een beetje overschrijden kan geen kwaad.</span></label>
    <label class="quiz-option"><input type="radio" name="q6" value="wrong2" onchange="checkQuiz()"> <span id="txt-q6-o2">Zo langzaam mogelijk rijden om het risico te beperken.</span></label>
    <label class="quiz-option"><input type="radio" name="q6" value="correct" onchange="checkQuiz()"> <span id="txt-q6-o3">Het maximale hefvermogen nooit overschrijden. Melden bij de voorman zodat een geschikter middel ingezet wordt.</span></label>
    <div id="feedback-q6" class="feedback"></div>
    <div style="margin-top:16px;padding-top:14px;border-top:1px solid #d0d8e4;">
      <p id="txt-video-opt-label" style="font-size:12px;color:#888;margin-bottom:6px;">Wil je zien wat er kan gebeuren als regels niet gevolgd worden? (optioneel, eigen keuze)</p>
      <a href="https://www.youtube.com/watch?v=2PEDmqB7VZ8" target="_blank" class="warning-video-btn">
        &#9888; <span id="txt-video-opt-btn">Bekijk: heftruckongelukken — bewust kijken op eigen initiatief</span>
      </a>
      <div class="warning-box" id="txt-video-opt-warning">Deze video bevat beelden van ernstige heftruckongelukken. Dit is optioneel en geen onderdeel van de verplichte instructie. Bekijk hem alleen als u zich daar bewust voor kiest.</div>
    </div>
  </div>

  <!-- OPMERKINGEN -->
  <div class="section-card" style="border-left-color: var(--success-green);">
    <h3 style="color:var(--success-green);margin:0 0 8px 0;font-size:15px;" id="txt-sec-comments">Vragen of opmerkingen</h3>
    <label id="txt-label-comments" for="emp_comments">Heeft u vragen of opmerkingen? Uw vraag wordt binnen een week beantwoord door de KAM-afdeling.</label>
    <textarea id="emp_comments" rows="3" placeholder="..."></textarea>
  </div>

  <button id="submitBtn" class="btn" disabled onclick="submitToolbox()">Toolbox Aftekenen</button>
</div>

<div id="confirmation-screen">
  <div class="confirm-icon">&#10003;</div>
  <div class="confirm-title" id="conf-title">Toolbox afgetekend</div>
  <div class="confirm-sub" id="conf-sub">Uw deelname is geregistreerd. U kunt deze pagina sluiten.</div>
  <div class="confirm-detail" id="conf-detail"></div>
</div>
</div>
</div>

<script>
let alreadySubmitted = false;
let currentLang = "nl";

const oorzaken = {
