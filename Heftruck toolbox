function updateOorzaken(lang) {
  const lst = oorzaken[lang] || oorzaken.nl;
  for (let i = 1; i <= 7; i++) {
    const el = document.getElementById("o"+i+"-txt");
    if (el) el.innerText = lst[i-1];
  }
}

